# idealab GPU Operator Configuration

# Operator
LOG_LEVEL=info
LOG_FORMAT=json
HEALTH_PORT=8081

# Kubernetes
KUBECONFIG=/etc/rancher/k3s/k3s.yaml
K3S_NODE_NAME=localhost

# GPU
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Helm Chart Defaults
DEFAULT_GPU_MEMORY_LIMIT=0
DEFAULT_CPU_LIMIT=4000m
DEFAULT_MEMORY_LIMIT=8Gi
